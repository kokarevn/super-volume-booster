{
  "manifest_version": 3,
  "name": "Super Volume Booster & Equalizer",
  "version": "1.0",
  "description": "Усиление звука до 600% и эквалайзер для браузера",
  "permissions": [
    "activeTab",
    "tabCapture",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume Booster"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}